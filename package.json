{
  "name": "web-design-encyclopedia",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://rishadeb.github.io/webdesigndemo/",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "build:pages": "node ./node_modules/vite/bin/vite.js build --base=/webdesigndemo/",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "predeploy": "npm run build:pages",
    "deploy": "gh-pages -d dist --nojekyll"
  },
  "dependencies": {
    "framer-motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^7.0.0"
  }
}
